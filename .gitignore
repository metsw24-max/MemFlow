# ============================================================================
# Maven build outputs
# ============================================================================
/target/
dependency-reduced-pom.xml
.flattened-pom.xml
*.versionsBackup
*.releaseBackup

# ============================================================================
# Compiled Java bytecode (defensive — Maven already routes these into target/)
# ============================================================================
*.class

# ============================================================================
# Local demo & test outputs
# Generated by `mvn exec:java -Dexec.args="--run-indexer"` and the
# reproduceIndexNameHeaderInjection test in LogRecordIndexerTest.
# ============================================================================
/logs_index/
/build/test-export/
/logs/

# ============================================================================
# JVM crash & diagnostic outputs (produced by the sanitizer profile and by
# the `@Disabled` crash reproducers when contributors enable them locally)
# ============================================================================
hs_err_pid*.log
hs_err_pid*
replay_pid*.log
replay_pid*
*.hprof
core.*
javacore.*.txt
Snap.*.trc
heapdump.*
target/heap-dumps/

# ============================================================================
# Log files
# ============================================================================
*.log
*.log.*
logs/

# ============================================================================
# IDE — IntelliJ IDEA
# ============================================================================
.idea/
*.iml
*.iws
*.ipr
out/

# ============================================================================
# IDE — Eclipse / JDT
# ============================================================================
.settings/
.project
.classpath
.factorypath
.apt_generated/
.springBeans
.metadata/
bin/

# ============================================================================
# IDE — VS Code
# ============================================================================
.vscode/
*.code-workspace
.history/

# ============================================================================
# IDE — NetBeans
# ============================================================================
nbproject/
nbactions.xml
nb-configuration.xml

# ============================================================================
# Editor temp / backup files
# ============================================================================
*.swp
*.swo
*.bak
*.orig
*.tmp
*~

# ============================================================================
# Operating system metadata
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
# Linux
.directory
.fuse_hidden*
.Trash-*

# ============================================================================
# Coverage / static analysis reports (if contributors run these locally)
# ============================================================================
.jacoco/
jacoco.exec
*.exec
spotbugsXml.xml
.scannerwork/
.sonar/

# ============================================================================
# Secrets — never commit these, even by accident
# ============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore
secrets.properties
application-local.properties
application-secret.properties
